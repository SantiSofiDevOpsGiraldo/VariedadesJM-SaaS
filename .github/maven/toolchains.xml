<?xml version="1.0" encoding="UTF-8"?>
<toolchains>
  <toolchain>
    <type>jdk</type>
    <provides>
      <version>21</version>
      <vendor>eclipse-temurin</vendor>
    </provides>
    <configuration>
      <!-- CI runners typically provide Temurin/OpenJDK installations.
           This file instructs Maven toolchains to select a JDK 21 vendor match.
           The `maven-toolchains-plugin` configured in `pom.xml` below points
           to this file via the `toolchainsFile` configuration. -->
    </configuration>
  </toolchain>
</toolchains>
